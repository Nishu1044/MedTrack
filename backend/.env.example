# --- Required ---
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/medtrack
JWT_SECRET=replace-with-a-long-random-string-min-32-chars

# Comma-separated list of allowed frontend origins (no trailing slash)
# Example: https://medtrack.vercel.app,http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# Public frontend URL — used to build password-reset links in emails.
# No trailing slash.
FRONTEND_URL=http://localhost:5173

# --- Email — choose ONE provider (Resend wins if both set) ---

# Provider A: Gmail SMTP (free, ~500/day)
# Generate App Password at https://myaccount.google.com/apppasswords
# (2FA must be enabled first: https://myaccount.google.com/security)
EMAIL_USER=your-gmail@gmail.com
EMAIL_APP_PASSWORD=xxxxxxxxxxxxxxxx
EMAIL_FROM=MedTrack <your-gmail@gmail.com>

# Provider B: Resend (free 3000/month, no Gmail needed)
# Sign up at https://resend.com to get API key
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# RESEND_FROM_EMAIL=MedTrack <onboarding@resend.dev>

# --- Cron endpoint protection ---
# Long random string. Required header `x-cron-secret` (or ?secret=) to call /api/cron/*
# Generate with: openssl rand -hex 32
CRON_SECRET=replace-with-another-long-random-string

# --- Optional ---
PORT=5000
NODE_ENV=development
